# ============================================================
# Traffic Analytics Platform — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# Server
PORT=3000
NODE_ENV=production
HOST=0.0.0.0

# Security
JWT_SECRET=change-me-to-a-very-long-random-string-in-production
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# Database
DB_PATH=./data/analytics.db

# Admin (first-run defaults — change immediately)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_EMAIL=admin@example.com

# GeoIP (ip-api.com — free, 45 req/min; set to 'local' for MaxMind)
GEOIP_PROVIDER=ipapi
# MAXMIND_DB_PATH=./data/GeoLite2-City.mmdb

# Privacy
ENABLE_IP_LOGGING=true
ANONYMIZE_IPS=false

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=300

# Data Retention (days; 0 = unlimited)
DATA_RETENTION_DAYS=365

# CORS — comma-separated list of allowed origins (* = all)
CORS_ORIGINS=*

# Session timeout (minutes of inactivity before session is marked ended)
SESSION_TIMEOUT_MINUTES=30
